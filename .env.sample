# ════════════════════════════════════════════════════════
#  OpenTrader — Environment Configuration Sample
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ════════════════════════════════════════════════════════

# ── LLM — OpenRouter ─────────────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default models per agent (can be overridden per agent in system.toml)
# Format: provider/model-name  (OpenRouter unified naming)
LLM_PREDICTOR_MODEL=anthropic/claude-sonnet-4-5
LLM_REVIEW_MODEL=anthropic/claude-opus-4-5
LLM_EOD_MODEL=anthropic/claude-sonnet-4-5
LLM_ORCHESTRATOR_MODEL=anthropic/claude-haiku-4-5
# Fallback model if primary is unavailable
LLM_FALLBACK_MODEL=openai/gpt-4o

# ── AgentMail ────────────────────────────────────────────────────────────────
# Get your key at: https://agentmail.to
AGENTMAIL_API_KEY=your_agentmail_api_key
AGENTMAIL_BASE_URL=https://api.agentmail.to

# Inboxes created — free tier = 3 max; ot-review shares ot-alerts inbox
AGENTMAIL_ORCHESTRATOR_INBOX=ot-orchestrator
AGENTMAIL_REVIEW_INBOX=ot-review
AGENTMAIL_EOD_INBOX=ot-eod
AGENTMAIL_ALERTS_INBOX=ot-eod

# Where EOD reports + review findings get delivered
REPORT_RECIPIENT_EMAIL=your_email@example.com

# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather; get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=your_discord_webhook_url
DISCORD_WEBHOOK_ALERTS=your_discord_alerts_webhook
DISCORD_WEBHOOK_TRADES=your_discord_trades_webhook
DISCORD_WEBHOOK_EOD=your_discord_eod_webhook
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_discord_channel_id
DISCORD_ALLOWED_GUILDS=
DISCORD_INTENTS=

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=your_db_password
VAULT_TOKEN=your_vault_token
GRAFANA_PASSWORD=your_grafana_password

# ── Schedule ─────────────────────────────────────────────────────────────────
MARKET_OPEN=09:30
MARKET_CLOSE=16:00
SCRAPE_INTERVAL_MINUTES=3
EOD_REPORT_TIME=16:05
REVIEW_TRADE_THRESHOLD=50
TIMEZONE=America/New_York

# ── Risk controls ────────────────────────────────────────────────────────────
MAX_POSITION_SIZE_USD=1000
MAX_DAILY_LOSS_USD=500
CIRCUIT_BREAKER_LOSS_PCT=5

# ── Data sources ─────────────────────────────────────────────────────────────
OVTLYR_EMAIL=your_ovtlyr_email
OVTLYR_PASSWORD=your_ovtlyr_password
OVTLYR_BASE_URL=https://console.ovtlyr.com

# ── Broker — Tradier ─────────────────────────────────────────────────────────
# Sandbox (paper trading): https://developer.tradier.com
TRADIER_SANDBOX_API_KEY=your_tradier_sandbox_api_key
TRADIER_SANDBOX_ACCOUNT_NUMBER=your_tradier_sandbox_account_number
TRADIER_SANDBOX_DISPLAY_NAME=Tradier Paper Account
# Production accounts (up to 4)
TRADIER_PRODUCTION_API_KEY=your_tradier_production_api_key
TRADIER_PROD_ACCOUNT_1=your_tradier_account_1
TRADIER_PROD_ACCOUNT_1_IRA=false
TRADIER_PROD_ACCOUNT_2=your_tradier_account_2
TRADIER_PROD_ACCOUNT_2_IRA=false
TRADIER_PROD_ACCOUNT_3=your_tradier_account_3
TRADIER_PROD_ACCOUNT_3_IRA=false
TRADIER_PROD_ACCOUNT_4=your_tradier_account_4
TRADIER_PROD_ACCOUNT_4_IRA=false
TRADIER_PROD_1_DISPLAY_NAME=
TRADIER_PROD_2_DISPLAY_NAME=
TRADIER_PROD_3_DISPLAY_NAME=
TRADIER_PROD_4_DISPLAY_NAME=
TRADIER_MAX_RETRIES=3
TRADIER_RATE_LIMIT_PER_SEC=2
TRADE_MODE=sandbox

# ── Broker — Alpaca ───────────────────────────────────────────────────────────
# Paper trading: https://alpaca.markets (free account)
ALPACA_API_KEY=your_alpaca_paper_api_key
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key
ALPACA_API_SECRET_KEY=your_alpaca_paper_api_key
ALPACA_PAPER_ACCOUNT_ID=your_alpaca_paper_account_id
ALPACA_PAPER_ACCOUNT_IRA=false
ALPACA_PAPER_DISPLAY_NAME=Alpaca Paper Account
# Live account
ALPACA_LIVE_API_SECRET_KEY=your_alpaca_live_secret_key
ALPACA_LIVE_ACCOUNT_ID=your_alpaca_live_account_id
ALPACA_LIVE_ACCOUNT_IRA=false
ALPACA_LIVE_DISPLAY_NAME=Alpaca Live Account
ALPACA_DATA_FEED=iex

# ── Broker — Webull ───────────────────────────────────────────────────────────
WEBULL_API_KEY=your_webull_api_key
WEBULL_SECRET_KEY=your_webull_secret_key
# Live accounts (up to 5)
WEBULL_LIVE_ACCOUNT_1=your_webull_account_1
WEBULL_LIVE_ACCOUNT_1_IRA=false
WEBULL_LIVE_ACCOUNT_2=your_webull_account_2
WEBULL_LIVE_ACCOUNT_2_IRA=false
WEBULL_LIVE_ACCOUNT_3=your_webull_account_3
WEBULL_LIVE_ACCOUNT_3_IRA=false
WEBULL_LIVE_ACCOUNT_4=your_webull_account_4
WEBULL_LIVE_ACCOUNT_4_IRA=false
WEBULL_LIVE_ACCOUNT_5=your_webull_account_5
WEBULL_LIVE_ACCOUNT_5_IRA=false
WEBULL_LIVE_1_DISPLAY_NAME=
WEBULL_LIVE_2_DISPLAY_NAME=
WEBULL_LIVE_3_DISPLAY_NAME=
WEBULL_LIVE_4_DISPLAY_NAME=
WEBULL_LIVE_5_DISPLAY_NAME=

# ── Massive.com (formerly Polygon.io) ──────────────────────────────────────
MASSIVE_API_KEY=your_massive_api_key

# ── Podman socket ────────────────────────────────────────────────────────────
# Run `id -u` to find your UID and substitute it below.
# e.g. if `id -u` returns 1000, use /run/user/1000/podman/podman.sock
PODMAN_SOCK=/run/user/1003/podman/podman.sock
